        "institutionName": {
          "type": "string",
          "title": "InstitutionName",
          "description": "[E6, M] Performing institution",
          "miaybe": {
            "id": "E6",
            "status": "M"
          }
        },
        "fundingSource": {
          "type": "string",
          "title": "FundingSource",
          "description": "[E7, O] Grant or funding information",
          "miaybe": {
            "id": "E7",
            "status": "O"
          }
        },
        "publicationDOI": {
          "type": "string",
          "pattern": "^10\\.\\d{4,}(\\.\\d+)*/.*$",
          "title": "PublicationDOI",
          "description": "[E8, O] Associated publication DOI",
          "miaybe": {
            "id": "E8",
            "status": "O"
          }
        }
      }
